# GitHub Personal Access Token (Fine-grained, "Public repositories" read-only)
# Create at: https://github.com/settings/personal-access-tokens/new
# Zero account permissions needed — polling /events only requires authentication
# for the 5000 req/hr rate ceiling.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server HTTP port (currently unused in Phase 1 — server does not expose HTTP yet)
PORT=8080

# Rust tracing filter
# info                         — concise
# info,starquake_server=debug  — verbose (per-tick stats, 304 hits, rate-limit headers)
RUST_LOG=info,starquake_server=debug

# Postgres connection URL — optional.
# When set, the server hydrates today's counter + caches on boot and snapshots
# the live counter every 60s so restarts don't wipe accumulated stars. Raw
# WatchEvents are still never persisted (Rule 13). When unset, the server runs
# fully in-memory — fine for local dev.
# DATABASE_URL=postgresql://starquake:starquake@localhost:5432/starquake
